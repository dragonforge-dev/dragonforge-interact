; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dragonforge Interact v1.2"
config/description="A Godot plugin that adds Interact and Highlight nodes that can be used to make RigidBody3D, StaticBody3D and MeshInstance3D nodes interactive with the mouse. Also includes InteractionRayCast3D and InteractionShapeCast3D as well as a Corsshair control that can be used to interact in a 1st or 3rd person game that captures the mouse."
config/version="1.2"
run/main_scene="uid://oax4i6cd4rlf"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="uid://c1drhxy75fnt3"

[display]

mouse_cursor/custom_image="uid://cob3ylfmwc7bg"
mouse_cursor/custom_image_hotspot=Vector2(8, 4)

[editor_plugins]

enabled=PackedStringArray("res://addons/dragonforge_interact/plugin.cfg")

